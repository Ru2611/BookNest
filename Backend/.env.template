# PostgreSQL connection (preferred)
# Set a single DATABASE_URL, or set the DB_* variables below.
# Example DATABASE_URL using psycopg (psycopg3) or psycopg2-compatible URI:
# DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>"

# Example (replace placeholders):
# DATABASE_URL="postgresql://postgres:changeme@localhost:5432/book_nest"

# Alternatively provide components (useful for Docker secrets / k8s):
# DB_USER=postgres
# DB_PASSWORD=changeme
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=book_nest

# If you leave all of the above unset the app will fall back to SQLite
# for local development: sqlite:///./booknest.db

# Driver note:
# - For SQLAlchemy sync engines install psycopg[binary] (psycopg3) or psycopg2-binary
#   e.g. `pip install "psycopg[binary]"` or `pip install psycopg2-binary`
# - For async engines use asyncpg and an async SQLAlchemy driver.
